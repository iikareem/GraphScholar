# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# AI — oMLX (local, OpenAI-compatible)
# INGESTION_LIGHT_MODE=true  → skip LLM/embeddings (16GB RAM friendly POC)
INGESTION_LIGHT_MODE=false
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=your_omlx_api_key
CONCEPT_MODEL=mlx-community/Llama-3.2-1B-Instruct-4bit
EMBEDDING_MODEL=mlx-community/bge-m3-mlx-8bit
EMBEDDING_DIMENSIONS=1024

# Ingestion settings
CHUNK_WORD_LIMIT=400
CHUNK_OVERLAP_WORDS=40
MAX_CITATION_DEPTH=2

# MCP HTTP transport (npm run mcp:http) — localhost only, no auth yet
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
